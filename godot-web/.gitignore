# ============================================================================
# Godot 项目 GitIgnore
# ============================================================================

# Godot 编辑器缓存和导入文件
.godot/
.import/
*.tmp
*.import

# 自动生成的 UID 文件（可选，通常应该提交）
# .uid_cache.bin

# 导出的构建产物（这些应该放在 server/cmd/server/web/）
# 但以防万一在这里也忽略
*.exe
*.x86_64
*.wasm
*.pck
export_presets.cfg.user

# 崩溃日志
mono_crash.*.json
