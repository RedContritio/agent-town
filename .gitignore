# ============================================================================
# Agent-Town 顶层 GitIgnore
# 只包含通用规则，各子目录的特定规则放在子目录的 .gitignore 中
# ============================================================================

# ----------------------------------------------------------------------------
# IDE 和编辑器
# ----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
*.sublime-*

# ----------------------------------------------------------------------------
# 操作系统文件
# ----------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ----------------------------------------------------------------------------
# 环境变量和敏感信息
# ----------------------------------------------------------------------------
.env
.env.local
.env.*.local

# ----------------------------------------------------------------------------
# 日志文件
# ----------------------------------------------------------------------------
*.log
logs/

# ----------------------------------------------------------------------------
# 临时文件
# ----------------------------------------------------------------------------
tmp/
temp/
*.tmp
*.temp
*.cache
